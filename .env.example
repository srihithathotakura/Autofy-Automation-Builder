# ===== Backend (backend/.env) =====

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Server
PORT=5000
NODE_ENV=development

# Secrets - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secret_key_here
SESSION_SECRET=your_session_secret_here

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# URLs - used to build OAuth callback/redirect links and CORS origin.
# In development these default to localhost, so you can leave them unset.
# In production, set these to your deployed URLs, e.g.:
#   BACKEND_URL=https://autofy-backend.onrender.com
#   FRONTEND_URL=https://autofy.vercel.app
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

